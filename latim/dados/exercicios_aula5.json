          "palavrasChave": ["Ave Maria", "cheia de graça", "Senhor", "convosco"],
          "explicacao": "Saudação + atributo + declaração de presença do Senhor."
        },
        {
          "tipo": "lacuna",
          "pergunta": "Complete o final da oração: 'nunc et in hora mortis ___' (da nossa morte)",
          "resposta": "nostrae",
          "alternativas": ["nostrae", "Nostrae"],
          "explicacao": "'Nostrae' é o genitivo feminino singular do pronome possessivo 'noster' (nosso)."
        }
      ]
    }
  ]
